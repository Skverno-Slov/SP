<Page x:Class="LabWork17.View.DrivesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LabWork17.View" xmlns:viewmodel="clr-namespace:LabWork17.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:DrivesViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DrivesPage">

    <ListBox ItemsSource="{Binding Drives}" SelectedItem="{Binding SelectedDrive}" HorizontalContentAlignment="Stretch">
        <ListBox.InputBindings>
            <MouseBinding MouseAction="LeftDoubleClick" 
                      Command="{Binding OpenDriveCommand}"/>
        </ListBox.InputBindings>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <DockPanel Background="LightGray" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                    <DockPanel.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding DataContext.OpenDriveCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                    </DockPanel.InputBindings>
                    <DockPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Свойства" 
                                  Command="{Binding PlacementTarget.Tag.ShowPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}" />
                        </ContextMenu>
                    </DockPanel.ContextMenu>
                    <Image Source="/Res/Icons/Disk.png" Width="40" Height="40" Margin="5"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"/>

                        <ProgressBar Value="{Binding UsedPercentage, Mode=OneWay}" 
                                    Minimum="0" 
                                    Maximum="100" 
                                    Height="12" 
                                    Margin="0,5"/>

                        <TextBlock FontSize="10" Foreground="Gray">
                        <TextBlock Text="{Binding FreeSpaceDisplay, Mode=OneWay}"/>
                        <TextBlock Text=" свободно из "/>
                        <TextBlock Text="{Binding TotalSizeDisplay, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</Page>
