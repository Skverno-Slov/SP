<Page x:Class="LabWork17.View.Pages.FileListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LabWork17.View.Pages" xmlns:viewmodel="clr-namespace:LabWork17.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:FileListViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FileListPage">

    <DockPanel>
        <DataGrid AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Files}"
                  RowBackground="Gray"
                  AlternationCount="1"
                  AlternatingRowBackground="DarkGray"
                  SelectedItem="{Binding SelectedItem}">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenDirCommand}"/> 
            </DataGrid.InputBindings>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Копировать" 
                      Command="{Binding CopyCommand}" 
                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />

                    <MenuItem Header="Вставить" 
                      Command="{Binding PasteCommand}" />
                
                    <MenuItem Header="Сжать в zip" 
                      Command="{Binding CompressCommand}" 
                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />

                    <MenuItem Header="Извлечь из zip" 
                      Command="{Binding DecompressCommand}" 
                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Иконка">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Icon}" Width="30"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Путь" Binding="{Binding Fullpath}"/>
                <DataGridTextColumn Header="Размер" Binding="{Binding Size}"/>
                <DataGridTextColumn Header="Последнее изменение" Binding="{Binding LastUpdate}"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
